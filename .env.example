# =========================
# Database
# =========================
MONGODB_URI=

# =========================
# OpenAI - Optional
# =========================
# OPENAI_API_KEY=

# =========================
# AIMLAPI - LLM Provider
# =========================
AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=google/gemini-2.5-flash
AIMLAPI_AGENT_MODEL=google/gemini-2.5-flash-lite-preview
AIMLAPI_VERDICT_MODEL=google/gemini-2.5-flash
AIMLAPI_ENABLED=true
AIMLAPI_TIMEOUT_MS=30000

# =========================
# Bright Data - Core
# =========================
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_MODE=api
BRIGHT_DATA_ZONE=ami_marketplace_unlocker
BRIGHT_DATA_WEB_UNLOCKER_ZONE=ami_marketplace_unlocker
BRIGHT_DATA_SERP_ZONE=ami_marketplace_unlocker

# =========================
# Bright Data - Endpoints
# =========================
BRIGHT_DATA_WEB_UNLOCKER_ENDPOINT=https://api.brightdata.com/request
BRIGHT_DATA_SERP_ENDPOINT=https://api.brightdata.com/request
BRIGHT_DATA_WEB_SCRAPER_ENDPOINT=https://api.brightdata.com/datasets/v3/scrape
BRIGHT_DATA_WEB_SCRAPER_TRIGGER_ENDPOINT=https://api.brightdata.com/datasets/v3/trigger
BRIGHT_DATA_WEB_SCRAPER_PROGRESS_ENDPOINT=https://api.brightdata.com/datasets/v3/progress
BRIGHT_DATA_DISCOVER_ENDPOINT=https://api.brightdata.com/discover

# =========================
# Bright Data - Request Defaults
# =========================
BRIGHT_DATA_DEFAULT_FORMAT=raw
BRIGHT_DATA_DEFAULT_COUNTRY=us
BRIGHT_DATA_TIMEOUT_MS=30000
BRIGHT_DATA_MAX_REQUESTS_PER_ANALYSIS=5

# =========================
# Bright Data - Dataset IDs
# =========================
BRIGHT_DATA_AMAZON_PRODUCTS_DATASET_ID=gd_l7q7dkf244hwjntr0
BRIGHT_DATA_AMAZON_SEARCH_DATASET_ID=
BRIGHT_DATA_ALIBABA_PRODUCTS_DATASET_ID=gd_mljabfy23d62b7eqr
BRIGHT_DATA_ALIEXPRESS_PRODUCTS_DATASET_ID=gd_mlj9v75u1w1jvaxvwp
BRIGHT_DATA_TIKTOK_SHOP_PRODUCTS_DATASET_ID=gd_m45m1u911dsa4274pi
BRIGHT_DATA_TIKTOK_POSTS_PROFILE_DATASET_ID=gd_m7n5v2gq296pex2f5m
BRIGHT_DATA_TIKTOK_POSTS_SEARCH_DATASET_ID=

# =========================
# AMI Runtime
# =========================
AMI_USE_LIVE_WEB=true
AMI_DEMO_MODE=false
AMI_ALLOW_DEMO_FALLBACK=true
AMI_MAX_DISCOVERY_RESULTS=5
AMI_WEB_REQUEST_TIMEOUT_MS=30000

# =========================
# AMI Security
# =========================
AMI_SESSION_SECRET=node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AMI_CREDENTIAL_SECRET=node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# =========================
# Public App URL
# =========================
NEXT_PUBLIC_APP_URL=http://localhost:3000







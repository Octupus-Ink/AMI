# Normalized AMI environment template.
# Copy values from your private .env file, but keep secrets out of git.

MONGODB_URI=

# OPENAI_API_KEY=

AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=google/gemini-2.5-flash
AIMLAPI_AGENT_MODEL=google/gemini-2.5-flash-lite-preview
AIMLAPI_VERDICT_MODEL=google/gemini-2.5-flash
AIMLAPI_ENABLED=true
AIMLAPI_TIMEOUT_MS=30000

BRIGHT_DATA_MODE=api
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_ZONE=ami_marketplace_unlocker
BRIGHT_DATA_WEB_UNLOCKER_ZONE=ami_marketplace_unlocker

BRIGHT_DATA_WEB_SCRAPER_ENDPOINT=https://api.brightdata.com/datasets/v3/scrape
BRIGHT_DATA_WEB_UNLOCKER_ENDPOINT=https://api.brightdata.com/request
BRIGHT_DATA_WEB_SCRAPER_TRIGGER_ENDPOINT=https://api.brightdata.com/datasets/v3/trigger
BRIGHT_DATA_WEB_SCRAPER_PROGRESS_ENDPOINT=https://api.brightdata.com/datasets/v3/progress

BRIGHT_DATA_DEFAULT_COUNTRY=us
BRIGHT_DATA_DEFAULT_FORMAT=raw
BRIGHT_DATA_TIMEOUT_MS=30000
BRIGHT_DATA_MAX_REQUESTS_PER_ANALYSIS=5

BRIGHT_DATA_AMAZON_PRODUCTS_DATASET_ID=gd_l7q7dkf244hwjntr0
BRIGHT_DATA_AMAZON_PRODUCTS_DISCOVER_TYPE=discover_new
BRIGHT_DATA_AMAZON_PRODUCTS_DISCOVER_BY=keyword
BRIGHT_DATA_AMAZON_PRODUCTS_INPUT_KEY=keyword

# Preferred name (current). BRIGHT_DATA_EBAY_DATASET_ID is accepted as an alias.
BRIGHT_DATA_EBAY_KEYWORD_DATASET_ID=gd_ltr9mjt81n0zzdk1fb
BRIGHT_DATA_EBAY_DATASET_ID=gd_ltr9mjt81n0zzdk1fb
BRIGHT_DATA_EBAY_KEYWORD_DISCOVER_TYPE=discover_new
BRIGHT_DATA_EBAY_KEYWORD_DISCOVER_BY=keywords
BRIGHT_DATA_EBAY_KEYWORD_INPUT_KEY=keywords
BRIGHT_DATA_EBAY_CATEGORY_INPUT_KEY=url
BRIGHT_DATA_EBAY_PRODUCT_URL_INPUT_KEY=url
BRIGHT_DATA_EBAY_SHOP_URL_INPUT_KEY=url

BRIGHT_DATA_ALIBABA_PRODUCTS_DATASET_ID=gd_mljabfy23d62b7eqr
BRIGHT_DATA_ALIEXPRESS_PRODUCTS_DATASET_ID=gd_mlj9v75u1w1jvaxvwp
BRIGHT_DATA_TIKTOK_SHOP_PRODUCTS_DATASET_ID=gd_m45m1u911dsa4274pi
BRIGHT_DATA_TIKTOK_POSTS_PROFILE_DATASET_ID=gd_m7n5v2gq296pex2f5m

BRIGHT_DATA_FACEBOOK_MARKETPLACE_DATASET_ID=
BRIGHT_DATA_FACEBOOK_MARKETPLACE_ENABLED=false
BRIGHT_DATA_FACEBOOK_MARKETPLACE_DISCOVER_TYPE=discover_new
BRIGHT_DATA_FACEBOOK_MARKETPLACE_DISCOVER_BY=keyword
BRIGHT_DATA_FACEBOOK_MARKETPLACE_INPUT_KEY=keyword
BRIGHT_DATA_FACEBOOK_MARKETPLACE_DEFAULT_CITY=New York
BRIGHT_DATA_FACEBOOK_MARKETPLACE_DEFAULT_DATE_LISTED=

AMI_USE_LIVE_WEB=true
AMI_DEMO_MODE=false
AMI_ALLOW_DEMO_FALLBACK=true
AMI_MAX_DISCOVERY_RESULTS=5
# Enable the extra LIVE eBay marketplace seller query for Supplier Comparison.
# Default OFF. Only runs for live (non-demo) runs. Amazon seller data needs no
# extra call (reused from Amazon Products records).
AMI_ENABLE_LIVE_MARKETPLACE_SELLER_DATA=false
AMI_WEB_REQUEST_TIMEOUT_MS=30000
AMI_SESSION_SECRET=
AMI_CREDENTIAL_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000
